# Optional: Override embedded OAuth credentials for self-hosting
# NANO_BANANA_CLIENT_ID=your-google-oauth-client-id
# NANO_BANANA_CLIENT_SECRET=your-google-oauth-client-secret

# Optional: Gemini API key (alternative to OAuth)
# GEMINI_API_KEY=your-gemini-api-key

# Optional: Custom image output directory (default: ~/nano-banana-images/)
# NANO_BANANA_OUTPUT_DIR=/path/to/images

# Optional: Custom credentials directory (default: ~/.nano-banana/)
# NANO_BANANA_CONFIG_DIR=/path/to/config
