{
  "name": "nano-banana-mcp",
  "version": "1.0.0",
  "description": "MCP server for AI image generation/editing using Google Gemini image models",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nano-banana-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "setup": "tsx src/index.ts setup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "keywords": ["mcp", "gemini", "image-generation", "ai", "google"],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "google-auth-library": "^9.0.0",
    "open": "^10.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
